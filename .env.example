# Vision ML System environment variables
# Copy this file to .env and fill values as needed.

# --------------------------------------------------
# DagsHub + MLflow (required for remote experiment tracking)
# --------------------------------------------------
DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_TOKEN=your_dagshub_access_token
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_access_token
# Optional explicit override (if omitted, dagshub.init config is used)
MLFLOW_TRACKING_URI=https://dagshub.com/your_dagshub_username/vision-ml-system.mlflow

# --------------------------------------------------
# Auto-labeling (required only when provider=roboflow)
# --------------------------------------------------
ROBOFLOW_API_KEY=your_roboflow_api_key

# --------------------------------------------------
# Optional run metadata tags used in MLflow
# --------------------------------------------------
ENV=development
USER=your_name
