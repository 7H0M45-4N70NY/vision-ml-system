# Vision ML System environment variables
# Copy this file to .env and fill values as needed.

# --------------------------------------------------
# DagsHub + MLflow (required for remote experiment tracking)
# --------------------------------------------------
DAGSHUB_USERNAME=your_dagshub_username
DAGSHUB_TOKEN=your_dagshub_access_token
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_access_token
# Optional explicit override (if omitted, dagshub.init config is used)
MLFLOW_TRACKING_URI=https://dagshub.com/your_dagshub_username/vision-ml-system.mlflow

# --------------------------------------------------
# DVC remote (DagsHub — same credentials as MLflow)
# --------------------------------------------------
# DVC reads these automatically when using the dagshub remote.
# Run: dvc remote modify dagshub --local password $DAGSHUB_TOKEN
# Or set below so scripts/dvc_cli.py can configure it at runtime.
DVC_REMOTE_PASSWORD=your_dagshub_access_token

# --------------------------------------------------
# Data Ingestion & Auto-labeling
# --------------------------------------------------
# ROBOFLOW_API_KEY: Required only when:
#   1. config/training/base.yaml has labeling.provider=roboflow, OR
#   2. Running prepare_data.py with --source roboflow
# 
# The inject_secrets() function in src/vision_ml/utils/config.py
# will automatically inject this into the config at runtime.
# This separates secrets (ENV) from configuration (YAML).
#
# Set this in .env or export ROBOFLOW_API_KEY=your_key
ROBOFLOW_API_KEY=your_roboflow_api_key

# --------------------------------------------------
# Optional run metadata tags used in MLflow
# --------------------------------------------------
ENV=development
USER=your_name
