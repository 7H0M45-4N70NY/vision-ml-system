# Add patterns of files dvc should ignore, which could improve
# the performance. Learn more at
# https://dvc.org/doc/user-guide/dvcignore

# Python artifacts
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Local temp and cache
.cache/
*.log

# Editor files
.idea/
.vscode/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# DVC local remote (not tracked by DVC)
data/dvc-local-remote/
